---
import PageLayout from '../../layouts/PageLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function getReadingTime(text: string): string {
  const words = text?.split(/\s+/).length || 0;
  return `${Math.ceil(words / 200)} min read`;
}
---

<PageLayout
  title="Blog"
  description="Technical essays, system designs, programming paradigms, and computing reflections."
>
  <div class="flex items-center justify-between mb-8 pb-4 border-b border-[var(--color-border)]">
    <span class="text-xs font-mono text-[var(--color-text-tertiary)] uppercase tracking-wider">
      {sortedPosts.length} post{sortedPosts.length !== 1 ? 's' : ''} published
    </span>
    <a
      href="/rss.xml"
      class="inline-flex items-center gap-1.5 text-xs font-mono text-[var(--color-accent-primary)] hover:underline uppercase tracking-wider"
      target="_blank"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 11a9 9 0 0 1 9 9"></path>
        <path d="M4 4a16 16 0 0 1 16 16"></path>
        <circle cx="5" cy="19" r="1"></circle>
      </svg>
      RSS Feed
    </a>
  </div>

  <div class="divide-y divide-[var(--color-border)]">
    {sortedPosts.map(post => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        slug={post.id}
        date={post.data.date}
        readingTime={getReadingTime(post.body || '')}
        categories={post.data.categories}
      />
    ))}

    {sortedPosts.length === 0 && (
      <p class="text-[var(--color-text-tertiary)] italic py-12 text-center">No blog articles published yet.</p>
    )}
  </div>
</PageLayout>
