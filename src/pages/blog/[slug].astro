---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const sorted = posts
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  
  return sorted.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: i < sorted.length - 1 ? { title: sorted[i + 1].data.title, slug: sorted[i + 1].id } : null,
      next: i > 0 ? { title: sorted[i - 1].data.title, slug: sorted[i - 1].id } : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content, headings } = await render(entry);

function getReadingTime(text: string): string {
  const words = text?.split(/\s+/).length || 0;
  return `${Math.ceil(words / 200)} min read`;
}
const readingTime = getReadingTime(entry.body || '');
---
<PostLayout frontmatter={entry.data} headings={headings} prev={prev} next={next} readingTime={readingTime}>
  <Content />
</PostLayout>
