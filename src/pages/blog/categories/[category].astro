---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';
import PostCard from '../../../components/PostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const activePosts = posts;
  const categories = [...new Set(activePosts.flatMap(p => p.data.categories || []))];

  return categories.map(category => ({
    params: { category },
    props: {
      category,
      posts: activePosts
        .filter(p => p.data.categories?.includes(category))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { category, posts } = Astro.props;

function getReadingTime(text: string): string {
  const words = text?.split(/\s+/).length || 0;
  return `${Math.ceil(words / 200)} min read`;
}
---

<PageLayout
  title={`Category: ${category}`}
  description={`Browse articles categorized under '${category}'.`}
  breadcrumbs={[
    { label: 'Blog', href: '/blog' },
    { label: category, href: `/blog/categories/${category}` }
  ]}
>
  <div class="mb-8">
    <a href="/blog" class="text-xs font-mono text-[var(--color-accent-primary)] hover:underline flex items-center gap-1">
      ← BACK TO ALL ARTICLES
    </a>
  </div>

  <div class="divide-y divide-[var(--color-border)]">
    {posts.map(post => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        slug={post.id}
        date={post.data.date}
        readingTime={getReadingTime(post.body || '')}
        categories={post.data.categories}
      />
    ))}
  </div>
</PageLayout>
