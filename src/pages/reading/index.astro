---
import PageLayout from '../../layouts/PageLayout.astro';
import BookCard from '../../components/BookCard.astro';
import { getCollection } from 'astro:content';

const allReading = await getCollection('reading');

// Group reading by category
const categories = ['books', 'articles', 'websites', 'papers', 'resources', 'bookmarks'] as const;
const groupedReading = categories.reduce((acc, cat) => {
  acc[cat] = allReading.filter(item => item.data.category === cat);
  return acc;
}, {} as Record<typeof categories[number], typeof allReading>);
---

<PageLayout
  title="Reading List"
  description="A curated catalog of books, technical papers, engineering articles, and digital bookmarks."
>
  <div class="space-y-16 mt-8">
    {categories.map(cat => {
      const items = groupedReading[cat];
      if (items.length === 0) return null;

      return (
        <section class="space-y-6">
          <div class="border-b border-[var(--color-border)] pb-2 flex items-baseline justify-between">
            <h2 class="font-serif text-xl font-bold tracking-tight text-[var(--color-text)] capitalize">
              {cat}
            </h2>
            <span class="text-xs font-mono text-[var(--color-text-tertiary)] uppercase tracking-wider">
              {items.length} {items.length === 1 ? 'item' : 'items'}
            </span>
          </div>

          <div class="grid sm:grid-cols-2 gap-6">
            {items.map(item => (
              <BookCard
                title={item.data.title}
                author={item.data.author}
                category={item.data.category}
                description={item.data.description}
                url={item.data.url}
                tags={item.data.tags}
              />
            ))}
          </div>
        </section>
      );
    })}

    {allReading.length === 0 && (
      <p class="text-[var(--color-text-tertiary)] italic py-12 text-center">No reading logs logged currently.</p>
    )}
  </div>
</PageLayout>
