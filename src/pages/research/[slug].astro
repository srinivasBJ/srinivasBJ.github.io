---
import { getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

export async function getStaticPaths() {
  const research = await getCollection('research');
  return research.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const formattedDate = new Date(entry.data.date).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---

<PageLayout
  title={entry.data.title}
  description={entry.data.description}
  breadcrumbs={[
    { label: 'Research', href: '/research' },
    { label: entry.data.title, href: `/research/${entry.id}` }
  ]}
>
  <div class="mb-8 flex items-center justify-between text-sm text-[var(--color-text-secondary)] border-b border-[var(--color-border)] pb-4">
    <div class="flex items-center gap-4">
      <time datetime={entry.data.date.toISOString()}>
        {formattedDate}
      </time>
      <span class="text-[var(--color-border)]">|</span>
      <span class="capitalize font-medium text-[var(--color-accent)]">
        {entry.data.category}
      </span>
    </div>
  </div>

  <article class="prose prose-lg max-w-none">
    <Content />
  </article>

  {entry.data.tags && entry.data.tags.length > 0 && (
    <div class="mt-12 pt-6 border-t border-[var(--color-border)] flex items-center gap-2">
      <span class="text-xs text-[var(--color-text-tertiary)] uppercase tracking-wider font-mono">Tags:</span>
      <div class="flex flex-wrap gap-1.5">
        {entry.data.tags.map((tag: string) => (
          <span class="text-xs px-2.5 py-0.5 rounded-full bg-[var(--color-bg-secondary)] text-[var(--color-text-secondary)]">
            #{tag}
          </span>
        ))}
      </div>
    </div>
  )}
</PageLayout>
