---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const allResearch = await getCollection('research');
const activeResearch = allResearch
  .filter(item => !item.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group research by category
const categories = ['papers', 'experiments', 'ideas', 'notes', 'talks'] as const;
const groupedResearch = categories.reduce((acc, cat) => {
  acc[cat] = activeResearch.filter(item => item.data.category === cat);
  return acc;
}, {} as Record<typeof categories[number], typeof activeResearch>);
---

<PageLayout
  title="Research & Notes"
  description="Explorations, experiments, papers, and presentations on computing, systems, and intelligence."
>
  <div class="space-y-16">
    {categories.map(cat => {
      const items = groupedResearch[cat];
      if (items.length === 0) return null;

      return (
        <section class="space-y-6">
          <div class="border-b border-[var(--color-border)] pb-2 flex items-baseline justify-between">
            <h2 class="text-2xl font-bold tracking-tight text-[var(--color-text)] capitalize">
              {cat}
            </h2>
            <span class="text-xs font-mono text-[var(--color-text-tertiary)] uppercase tracking-wider">
              {items.length} {items.length === 1 ? 'item' : 'items'}
            </span>
          </div>

          <div class="grid gap-6">
            {items.map(item => (
              <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-border-hover)] transition-all duration-200 shadow-sm relative group">
                <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
                  <span class="text-xs font-mono text-[var(--color-text-secondary)]">
                    {new Date(item.data.date).toLocaleDateString('en-US', {
                      year: 'numeric', month: 'short', day: 'numeric'
                    })}
                  </span>
                  <span class="text-[10px] font-mono uppercase tracking-wider px-2 py-0.5 rounded-md bg-[var(--color-bg-secondary)] text-[var(--color-text-secondary)] border border-[var(--color-border)]">
                    {item.data.category}
                  </span>
                </div>
                <h3 class="text-lg font-semibold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-200">
                  <a href={`/research/${item.id}`} class="focus:outline-none">
                    {item.data.title}
                    <span class="absolute inset-0" aria-hidden="true"></span>
                  </a>
                </h3>
                <p class="text-sm text-[var(--color-text-secondary)] mt-2 leading-relaxed">
                  {item.data.description}
                </p>
                {item.data.tags && item.data.tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-1.5 relative z-10">
                    {item.data.tags.map((tag: string) => (
                      <span class="text-[11px] px-2 py-0.5 rounded-md bg-[var(--color-bg-secondary)] text-[var(--color-text-secondary)]">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </section>
      );
    })}

    {activeResearch.length === 0 && (
      <div class="text-center py-12 border border-dashed border-[var(--color-border)] rounded-xl">
        <p class="text-[var(--color-text-secondary)]">No research notes published yet. Stay tuned!</p>
      </div>
    )}
  </div>
</PageLayout>
