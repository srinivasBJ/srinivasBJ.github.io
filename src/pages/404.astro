---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404: Page Not Found">
  <div class="flex-1 flex flex-col items-center justify-center min-h-[60vh] max-w-4xl mx-auto px-6 text-center">
    <div class="space-y-6">
      <h1 class="text-9xl font-bold tracking-tighter text-[var(--color-text-tertiary)] opacity-30 select-none">
        404
      </h1>
      
      <div class="space-y-2">
        <h2 class="text-3xl font-bold text-[var(--color-text)]">Lost in space</h2>
        <p class="text-[var(--color-text-secondary)] max-w-md mx-auto">
          The page you are looking for doesn't exist or has been moved to a new coordinate in the knowledge base.
        </p>
      </div>

      <div class="pt-6 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-[var(--color-accent)] text-white hover:bg-[var(--color-accent-hover)] transition-all duration-200 shadow-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
          Return Home
        </a>
        <button
          onclick="document.dispatchEvent(new CustomEvent('toggle-command-palette'))"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text)] hover:bg-[var(--color-bg-secondary)] transition-all duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          Search Site (⌘K)
        </button>
      </div>
    </div>
  </div>
</BaseLayout>
