---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404: Not Found">
  <div class="max-w-2xl mx-auto px-6 py-24 text-center space-y-6 animate-fade-in">
    <h1 class="font-serif text-8xl font-bold tracking-tight text-[var(--color-text-tertiary)] opacity-35 select-none">
      404
    </h1>
    <div class="space-y-2">
      <h2 class="font-serif text-2xl font-bold text-[var(--color-text)]">Note Not Found</h2>
      <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed max-w-sm mx-auto">
        The page you are looking for does not exist in this digital garden. It might have been pruned or moved.
      </p>
    </div>
    <div class="pt-4">
      <a
        href="/"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[var(--color-text)] text-[var(--color-bg)] font-mono text-xs font-bold hover:opacity-90 transition-opacity"
      >
        ← RETURN HOME
      </a>
    </div>
  </div>
</BaseLayout>
