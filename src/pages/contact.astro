---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Contact"
  description="Get in touch. I'm always open to discussing new opportunities, systems architectures, or sharing books."
>
  <div class="max-w-xl mx-auto mt-8">
    <div class="p-8 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] shadow-md">
      <h2 class="text-xl font-semibold text-[var(--color-text)] mb-6">Let's connect</h2>
      
      <p class="text-[var(--color-text-secondary)] leading-relaxed mb-8">
        If you'd like to collaborate on an open-source project, ask a question about my research, or just say hello, feel free to reach out. I try my best to respond to all thoughtful inquiries.
      </p>

      <div class="space-y-4">
        <!-- Email -->
        <a
          href="mailto:placeholder@example.com"
          class="flex items-center gap-4 p-4 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-accent)] hover:bg-[var(--color-bg-secondary)] transition-all duration-200 group"
        >
          <div class="p-3 rounded-lg bg-[var(--color-accent-subtle)] text-[var(--color-accent)] group-hover:bg-[var(--color-accent)] group-hover:text-white transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
          </div>
          <div>
            <div class="text-xs font-mono text-[var(--color-text-tertiary)] uppercase tracking-wider">Email</div>
            <div class="text-sm font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-200">
              placeholder@example.com
            </div>
          </div>
        </a>

        <!-- GitHub -->
        <a
          href="https://github.com/srinivasBJ"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 p-4 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-accent)] hover:bg-[var(--color-bg-secondary)] transition-all duration-200 group"
        >
          <div class="p-3 rounded-lg bg-[var(--color-accent-subtle)] text-[var(--color-accent)] group-hover:bg-[var(--color-accent)] group-hover:text-white transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
              <path d="M9 18c-4.51 2-5-2-7-2"></path>
            </svg>
          </div>
          <div>
            <div class="text-xs font-mono text-[var(--color-text-tertiary)] uppercase tracking-wider">GitHub</div>
            <div class="text-sm font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-200">
              github.com/srinivasBJ
            </div>
          </div>
        </a>
      </div>
    </div>
  </div>
</PageLayout>
