---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Admin Panel">
  <div class="max-w-6xl mx-auto px-6 py-12 animate-fade-in" id="admin-root">
    
    <!-- Login Panel (Prompt for PAT) -->
    <div id="auth-panel" class="max-w-md mx-auto py-16 hidden">
      <div class="p-8 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] shadow-md space-y-6">
        <div>
          <h2 class="font-serif text-2xl font-bold text-[var(--color-text)]">Access Publisher</h2>
          <p class="text-xs text-[var(--color-text-secondary)] mt-1">
            Authenticate using a GitHub Personal Access Token (PAT) with repository write scopes. Token is saved locally in your browser.
          </p>
        </div>

        <div class="space-y-4">
          <div>
            <label for="gh-token" class="block text-xs font-mono text-[var(--color-text-secondary)] uppercase tracking-wider mb-2">GitHub PAT (fine-grained or classic)</label>
            <input
              type="password"
              id="gh-token"
              placeholder="github_pat_..."
              class="w-full px-3.5 py-2.5 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-sm text-[var(--color-text)] outline-none focus:border-[var(--color-text-secondary)] font-mono"
            />
          </div>

          <div>
            <label for="gh-repo" class="block text-xs font-mono text-[var(--color-text-secondary)] uppercase tracking-wider mb-2">Repository</label>
            <input
              type="text"
              id="gh-repo"
              placeholder="srinivasBJ/srinivasBJ.github.io"
              class="w-full px-3.5 py-2.5 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-sm text-[var(--color-text)] outline-none focus:border-[var(--color-text-secondary)] font-mono"
            />
          </div>

          <button
            type="button"
            id="auth-btn"
            class="w-full py-2.5 rounded-lg bg-[var(--color-text)] text-[var(--color-bg)] font-medium hover:opacity-90 transition-opacity text-sm cursor-pointer"
          >
            Authenticate
          </button>
        </div>
      </div>
    </div>

    <!-- Main Workspace (Hidden by default) -->
    <div id="workspace-panel" class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-8 hidden">
      
      <!-- Left sidebar: Documents List -->
      <aside class="space-y-6 border-r border-[var(--color-border)] pr-8 h-[75vh] overflow-y-auto">
        <div class="flex items-center justify-between border-b border-[var(--color-border)] pb-4">
          <h2 class="font-serif text-lg font-bold">Documents</h2>
          <button
            type="button"
            id="new-btn"
            class="px-3 py-1.5 rounded-md bg-[var(--color-text)] text-[var(--color-bg)] text-xs font-mono font-semibold cursor-pointer hover:opacity-90 transition-opacity"
          >
            + NEW
          </button>
        </div>

        <!-- Document Collections Lists -->
        <div class="space-y-6" id="doc-lists">
          <div class="text-xs text-[var(--color-text-tertiary)] italic font-mono">Loading documents list...</div>
        </div>
        
        <div class="pt-4 border-t border-[var(--color-border)]">
          <button
            type="button"
            id="logout-btn"
            class="text-xs font-mono text-rose-500 hover:underline cursor-pointer"
          >
            Disconnect Account
          </button>
        </div>
      </aside>

      <!-- Right Workspace: Editor & Preview Pane -->
      <main class="space-y-6" id="editor-pane">
        <div class="flex items-center justify-between gap-4 border-b border-[var(--color-border)] pb-4">
          <div>
            <span class="text-[10px] font-mono uppercase tracking-wider px-2 py-0.5 rounded bg-[var(--color-bg-secondary)] border border-[var(--color-border)] text-[var(--color-text-secondary)]" id="edit-mode-label">New Document</span>
            <span class="text-xs font-mono text-[var(--color-text-tertiary)] ml-2" id="file-sha-label"></span>
          </div>
          <div class="flex items-center gap-2">
            <button
              type="button"
              id="preview-toggle"
              class="px-4 py-1.5 rounded-lg border border-[var(--color-border)] text-xs font-mono hover:bg-[var(--color-bg-secondary)] transition-colors cursor-pointer"
            >
              PREVIEW
            </button>
            <button
              type="button"
              id="save-btn"
              class="px-5 py-1.5 rounded-lg bg-[var(--color-text)] text-[var(--color-bg)] text-xs font-mono font-bold hover:opacity-90 transition-opacity cursor-pointer flex items-center gap-1.5"
            >
              <span>PUBLISH</span>
              <div id="save-spinner" class="w-3.5 h-3.5 border-2 border-[var(--color-bg)] border-t-transparent rounded-full animate-spin hidden"></div>
            </button>
          </div>
        </div>

        <!-- Editor Forms -->
        <div id="form-container" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="md:col-span-2">
              <label for="doc-title" class="block text-xs font-mono text-[var(--color-text-secondary)] uppercase tracking-wider mb-2">Title</label>
              <input
                type="text"
                id="doc-title"
                placeholder="Enter title…"
                class="w-full px-3.5 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-sm text-[var(--color-text)] outline-none focus:border-[var(--color-text-secondary)]"
              />
            </div>

            <div>
              <label for="doc-collection" class="block text-xs font-mono text-[var(--color-text-secondary)] uppercase tracking-wider mb-2">Collection</label>
              <select
                id="doc-collection"
                class="w-full px-3.5 py-2.5 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-sm text-[var(--color-text)] outline-none focus:border-[var(--color-text-secondary)] cursor-pointer"
              >
                <option value="blog">Blog (Articles)</option>
                <option value="lab">Lab (Garden Notes)</option>
                <option value="projects">Projects (Case Studies)</option>
                <option value="reading">Reading (Bookmarks)</option>
              </select>
            </div>
          </div>

          <!-- Metadata Fields -->
          <div class="grid grid-cols-1 md:grid-cols-4 gap-6" id="metadata-fields">
            <!-- Dynamic Category -->
            <div class="category-wrapper">
              <label for="doc-category" class="block text-xs font-mono text-[var(--color-text-secondary)] uppercase tracking-wider mb-2" id="category-label">Category</label>
              <!-- Reading dropdown or text input -->
              <div id="category-input-wrapper">
                <input
                  type="text"
                  id="doc-category"
                  placeholder="e.g. Linux, engineering…"
                  class="w-full px-3.5 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-sm text-[var(--color-text)] outline-none focus:border-[var(--color-text-secondary)]"
                />
              </div>
            </div>

            <!-- Dynamic Tags -->
            <div>
              <label for="doc-tags" class="block text-xs font-mono text-[var(--color-text-secondary)] uppercase tracking-wider mb-2">Tags</label>
              <input
                type="text"
                id="doc-tags"
                placeholder="comma-separated tags…"
                class="w-full px-3.5 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-sm text-[var(--color-text)] outline-none focus:border-[var(--color-text-secondary)] font-mono"
              />
            </div>

            <!-- Author / Source (Reading specific) -->
            <div id="author-wrapper" class="hidden">
              <label for="doc-author" class="block text-xs font-mono text-[var(--color-text-secondary)] uppercase tracking-wider mb-2">Author / Source</label>
              <input
                type="text"
                id="doc-author"
                placeholder="Robert C. Martin…"
                class="w-full px-3.5 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-sm text-[var(--color-text)] outline-none focus:border-[var(--color-text-secondary)]"
              />
            </div>

            <!-- External URL (Reading specific) -->
            <div id="url-wrapper" class="hidden">
              <label for="doc-url" class="block text-xs font-mono text-[var(--color-text-secondary)] uppercase tracking-wider mb-2">Link URL</label>
              <input
                type="text"
                id="doc-url"
                placeholder="https://example.com…"
                class="w-full px-3.5 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-sm text-[var(--color-text)] outline-none focus:border-[var(--color-text-secondary)] font-mono"
              />
            </div>

            <!-- Pinned checkbox (Blog specific) -->
            <div id="pinned-wrapper" class="flex items-center gap-2 pt-6">
              <input
                type="checkbox"
                id="doc-pinned"
                class="w-4 h-4 rounded border-[var(--color-border)] accent-[var(--color-text)]"
              />
              <label for="doc-pinned" class="text-xs font-mono text-[var(--color-text-secondary)] uppercase tracking-wider select-none cursor-pointer">Pin to Home</label>
            </div>

            <!-- Draft Checkbox -->
            <div class="flex items-center gap-2 pt-6">
              <input
                type="checkbox"
                id="doc-draft"
                class="w-4 h-4 rounded border-[var(--color-border)] accent-[var(--color-text)]"
              />
              <label for="doc-draft" class="text-xs font-mono text-[var(--color-text-secondary)] uppercase tracking-wider select-none cursor-pointer">Draft Mode</label>
            </div>
          </div>

          <!-- Description (Markdown abstract) -->
          <div>
            <label for="doc-description" class="block text-xs font-mono text-[var(--color-text-secondary)] uppercase tracking-wider mb-2">Description / Abstract</label>
            <textarea
              id="doc-description"
              rows="2"
              placeholder="Short summary of this document…"
              class="w-full px-3.5 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-sm text-[var(--color-text)] outline-none focus:border-[var(--color-text-secondary)] resize-y"
            ></textarea>
          </div>

          <!-- Body Editor Area with Drag-and-Drop Dropzone -->
          <div class="relative group/editor">
            <label for="doc-body" class="block text-xs font-mono text-[var(--color-text-secondary)] uppercase tracking-wider mb-2">Content Body (Markdown)</label>
            
            <div
              id="drag-overlay"
              class="absolute inset-0 bg-[var(--color-bg)]/90 border-2 border-dashed border-[var(--color-text-secondary)] rounded-lg flex items-center justify-center z-25 hidden animate-fade-in"
            >
              <div class="text-center space-y-2 pointer-events-none">
                <svg class="w-8 h-8 text-[var(--color-text-secondary)] mx-auto animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                </svg>
                <p class="text-xs font-mono text-[var(--color-text)]">Drop image here to commit & upload</p>
              </div>
            </div>

            <textarea
              id="doc-body"
              rows="15"
              placeholder="Write your markdown body here…"
              class="w-full p-4 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-sm text-[var(--color-text)] outline-none focus:border-[var(--color-text-secondary)] font-mono resize-y"
            ></textarea>
          </div>
        </div>

        <!-- Preview Container -->
        <div id="preview-container" class="hidden p-8 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] prose max-w-none">
          <h1 id="prev-title"></h1>
          <div id="prev-content"></div>
        </div>
      </main>
    </div>
  </div>

  <!-- Client-side script handling all authentication and GitHub sync operations -->
  <script is:inline>
    (function () {
      let githubToken = '';
      let repoFullName = '';
      let activeDoc = null; // { path, sha, name, collection }

      const authPanel = document.getElementById('auth-panel');
      const workspacePanel = document.getElementById('workspace-panel');
      const authBtn = document.getElementById('auth-btn');
      const logoutBtn = document.getElementById('logout-btn');
      const tokenInput = document.getElementById('gh-token');
      const repoInput = document.getElementById('gh-repo');
      
      const docLists = document.getElementById('doc-lists');
      const newBtn = document.getElementById('new-btn');
      const saveBtn = document.getElementById('save-btn');
      const saveSpinner = document.getElementById('save-spinner');
      const previewToggle = document.getElementById('preview-toggle');
      
      const editorForm = document.getElementById('form-container');
      const previewPane = document.getElementById('preview-container');
      const dragOverlay = document.getElementById('drag-overlay');
      const editLabel = document.getElementById('edit-mode-label');
      const shaLabel = document.getElementById('file-sha-label');

      // Inputs
      const titleInput = document.getElementById('doc-title');
      const colInput = document.getElementById('doc-collection');
      const tagsInput = document.getElementById('doc-tags');
      const descInput = document.getElementById('doc-description');
      const bodyInput = document.getElementById('doc-body');
      const pinnedInput = document.getElementById('doc-pinned');
      const draftInput = document.getElementById('doc-draft');
      
      // Reading-specific inputs
      const authorInput = document.getElementById('doc-author');
      const urlInput = document.getElementById('doc-url');
      
      const authorWrapper = document.getElementById('author-wrapper');
      const urlWrapper = document.getElementById('url-wrapper');
      const pinnedWrapper = document.getElementById('pinned-wrapper');
      const categoryInputWrapper = document.getElementById('category-input-wrapper');
      const categoryLabel = document.getElementById('category-label');

      // Initialize
      function init() {
        githubToken = localStorage.getItem('gh_pat') || '';
        repoFullName = localStorage.getItem('gh_repo') || '';

        if (githubToken && repoFullName) {
          authPanel.classList.add('hidden');
          workspacePanel.classList.remove('hidden');
          tokenInput.value = githubToken;
          repoInput.value = repoFullName;
          loadDocuments();
          setupNewDoc();
        } else {
          authPanel.classList.remove('hidden');
          workspacePanel.classList.add('hidden');
        }
      }

      // Save credentials
      authBtn.addEventListener('click', () => {
        const token = tokenInput.value.trim();
        const repo = repoInput.value.trim();

        if (token && repo) {
          localStorage.setItem('gh_pat', token);
          localStorage.setItem('gh_repo', repo);
          init();
        } else {
          alert('Token and Repository name are required.');
        }
      });

      // Clear credentials
      logoutBtn.addEventListener('click', () => {
        localStorage.removeItem('gh_pat');
        localStorage.removeItem('gh_repo');
        location.reload();
      });

      // Toggle Reading/Blog layout specifics
      colInput.addEventListener('change', () => {
        updateFieldVisibility();
      });

      function updateFieldVisibility() {
        const col = colInput.value;
        if (col === 'reading') {
          authorWrapper.classList.remove('hidden');
          urlWrapper.classList.remove('hidden');
          pinnedWrapper.classList.add('hidden');
          categoryLabel.textContent = 'Category';
          categoryInputWrapper.innerHTML = `
            <select id="doc-category" class="w-full px-3.5 py-2.5 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-sm text-[var(--color-text)] outline-none focus:border-[var(--color-text-secondary)] cursor-pointer">
              <option value="books">Books</option>
              <option value="articles">Articles</option>
              <option value="websites">Websites</option>
              <option value="papers">Papers</option>
              <option value="resources">Resources</option>
              <option value="bookmarks">Bookmarks</option>
            </select>
          `;
        } else {
          authorWrapper.classList.add('hidden');
          urlWrapper.classList.add('hidden');
          categoryLabel.textContent = 'Category / Section';
          categoryInputWrapper.innerHTML = `
            <input type="text" id="doc-category" placeholder="e.g. Linux, AWS, engineering…" class="w-full px-3.5 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-sm text-[var(--color-text)] outline-none focus:border-[var(--color-text-secondary)]"/>
          `;
          if (col === 'blog') {
            pinnedWrapper.classList.remove('hidden');
          } else {
            pinnedWrapper.classList.add('hidden');
          }
        }
      }

      // Fetch file tree from GitHub
      async function fetchGitHub(endpoint, options = {}) {
        const url = `https://api.github.com/repos/${repoFullName}/${endpoint}`;
        const headers = {
          'Authorization': `token ${githubToken}`,
          'Accept': 'application/vnd.github.v3+json',
          'Content-Type': 'application/json'
        };

        const res = await fetch(url, { headers, ...options });
        if (!res.ok) {
          const err = await res.json();
          throw new Error(err.message || 'GitHub API error');
        }
        return res.json();
      }

      // List all docs in content folders
      async function loadDocuments() {
        docLists.innerHTML = '<div class="text-xs font-mono text-[var(--color-text-tertiary)] animate-pulse">Fetching lists…</div>';
        
        try {
          const collections = ['blog', 'lab', 'projects', 'reading'];
          let html = '';

          for (const col of collections) {
            html += `<div class="space-y-2">
              <h3 class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-tertiary)] border-b border-[var(--color-border)] pb-1">${col}</h3>
              <ul class="space-y-1.5 max-h-40 overflow-y-auto pr-2">`;

            try {
              const files = await fetchGitHub(`contents/src/content/${col}`);
              const mdFiles = files.filter(f => f.name.endsWith('.md') || f.name.endsWith('.mdx'));

              if (mdFiles.length === 0) {
                html += '<li class="text-xs text-[var(--color-text-tertiary)] italic pl-2">No files</li>';
              } else {
                mdFiles.forEach(file => {
                  html += `<li>
                    <button
                      type="button"
                      class="doc-link w-full text-left truncate text-xs text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:underline cursor-pointer pl-2 block font-mono"
                      data-path="${file.path}"
                      data-sha="${file.sha}"
                      data-name="${file.name}"
                      data-collection="${col}"
                    >
                      ${file.name.replace(/\.mdx?$/, '')}
                    </button>
                  </li>`;
                });
              }
            } catch (e) {
              html += `<li class="text-xs text-rose-500 pl-2 italic">Unreleased or empty</li>`;
            }

            html += '</ul></div>';
          }

          docLists.innerHTML = html;

          // Add click events to links
          document.querySelectorAll('.doc-link').forEach(link => {
            link.addEventListener('click', (e) => {
              const dataset = e.currentTarget.dataset;
              loadDoc(dataset.path, dataset.sha, dataset.name, dataset.collection);
            });
          });

        } catch (error) {
          docLists.innerHTML = `<div class="text-xs text-rose-500 font-mono">Error: ${error.message}</div>`;
        }
      }

      // Parse YAML frontmatter
      function parseFrontmatter(text) {
        const match = text.match(/^---\r?\n([\s\S]+?)\r?\n---\r?\n([\s\S]*)$/);
        if (!match) return { data: {}, body: text };

        const yamlBlock = match[1];
        const body = match[2];
        const data = {};

        yamlBlock.split('\n').forEach(line => {
          const colonIdx = line.indexOf(':');
          if (colonIdx === -1) return;
          const key = line.slice(0, colonIdx).trim();
          let value = line.slice(colonIdx + 1).trim();

          // Clean quotes and array formats
          if (value.startsWith('"') && value.endsWith('"')) {
            value = value.slice(1, -1);
          } else if (value.startsWith("'") && value.endsWith("'")) {
            value = value.slice(1, -1);
          } else if (value.startsWith('[') && value.endsWith(']')) {
            value = value.slice(1, -1).split(',').map(s => s.trim().replace(/^['"]|['"]$/g, ''));
          } else if (value === 'true') {
            value = true;
          } else if (value === 'false') {
            value = false;
          }

          data[key] = value;
        });

        return { data, body };
      }

      // Convert fields to YAML frontmatter
      function jsonToYaml(data) {
        let yaml = '---\n';
        for (const [key, value] of Object.entries(data)) {
          if (Array.isArray(value)) {
            yaml += `${key}: [${value.map(v => `"${v}"`).join(', ')}]\n`;
          } else if (typeof value === 'boolean' || typeof value === 'number') {
            yaml += `${key}: ${value}\n`;
          } else if (value instanceof Date) {
            yaml += `${key}: ${value.toISOString().split('T')[0]}\n`;
          } else {
            yaml += `${key}: "${value.replace(/"/g, '\\"')}"\n`;
          }
        }
        yaml += '---\n';
        return yaml;
      }

      // Load specific document into editor
      async function loadDoc(path, sha, name, collection) {
        editLabel.textContent = `Editing: ${collection}/${name}`;
        shaLabel.textContent = `SHA: ${sha.slice(0, 7)}`;
        saveBtn.querySelector('span').textContent = 'SAVE CHANGES';
        
        try {
          const fileData = await fetchGitHub(`contents/${path}`);
          const content = decodeURIComponent(escape(atob(fileData.content)));
          const parsed = parseFrontmatter(content);
          
          activeDoc = { path, sha, name, collection };

          // Populate inputs
          titleInput.value = parsed.data.title || '';
          colInput.value = collection;
          updateFieldVisibility();

          // Get category
          setTimeout(() => {
            const catField = document.getElementById('doc-category');
            if (catField) {
              catField.value = parsed.data.category || (parsed.data.categories ? parsed.data.categories[0] : '');
            }
          }, 50);

          tagsInput.value = Array.isArray(parsed.data.tags) ? parsed.data.tags.join(', ') : (parsed.data.tags || '');
          descInput.value = parsed.data.description || '';
          bodyInput.value = parsed.body || '';
          draftInput.checked = parsed.data.draft === true;
          if (pinnedInput) {
            pinnedInput.checked = parsed.data.pinned === true;
          }

          if (collection === 'reading') {
            authorInput.value = parsed.data.author || '';
            urlInput.value = parsed.data.url || '';
          }

          // Reset preview
          closePreview();

        } catch (error) {
          alert(`Error loading file: ${error.message}`);
        }
      }

      // Reset editor for a new document
      function setupNewDoc() {
        activeDoc = null;
        editLabel.textContent = 'New Document';
        shaLabel.textContent = '';
        saveBtn.querySelector('span').textContent = 'PUBLISH';

        titleInput.value = '';
        colInput.value = 'blog';
        updateFieldVisibility();
        
        setTimeout(() => {
          const catField = document.getElementById('doc-category');
          if (catField) catField.value = '';
        }, 50);

        tagsInput.value = '';
        descInput.value = '';
        bodyInput.value = '';
        draftInput.checked = false;
        if (pinnedInput) pinnedInput.checked = false;
        
        closePreview();
      }

      newBtn.addEventListener('click', setupNewDoc);

      // Save/Publish document
      saveBtn.addEventListener('click', async () => {
        const title = titleInput.value.trim();
        const collection = colInput.value;
        const body = bodyInput.value;
        const desc = descInput.value.trim();
        
        const catField = document.getElementById('doc-category');
        const category = catField ? catField.value.trim() : '';

        if (!title || !body) {
          alert('Title and Content Body are required.');
          return;
        }

        // Generate filename from title
        const slug = title.toLowerCase()
          .replace(/[^\w\s-]/g, '')
          .replace(/[\s_]+/g, '-')
          .replace(/^-+|-+$/g, '');
        
        const filename = `${slug}.md`;
        const path = `src/content/${collection}/${filename}`;

        saveSpinner.classList.remove('hidden');
        saveBtn.disabled = true;

        try {
          // Prepare frontmatter
          const tags = tagsInput.value.split(',').map(s => s.trim()).filter(Boolean);
          const frontmatterData = {
            title,
            description: desc,
            date: activeDoc ? new Date() : new Date(), // Keep existing date or set new
            tags,
            draft: draftInput.checked
          };

          if (collection === 'blog') {
            frontmatterData.categories = [category];
            frontmatterData.pinned = pinnedInput.checked;
          } else if (collection === 'lab') {
            frontmatterData.category = category;
          } else if (collection === 'reading') {
            frontmatterData.author = authorInput.value.trim();
            frontmatterData.category = category; // books, articles, etc.
            if (urlInput.value.trim()) {
              frontmatterData.url = urlInput.value.trim();
            }
          }

          const fileContent = jsonToYaml(frontmatterData) + '\n' + body;
          const encodedContent = btoa(unescape(encodeURIComponent(fileContent)));

          const bodyPayload = {
            message: activeDoc 
              ? `Update document: ${filename}`
              : `Create document: ${filename}`,
            content: encodedContent,
            branch: 'main'
          };

          if (activeDoc) {
            bodyPayload.sha = activeDoc.sha;
          }

          // Commit to GitHub
          const targetPath = activeDoc ? activeDoc.path : path;
          const result = await fetchGitHub(`contents/${targetPath}`, {
            method: 'PUT',
            body: JSON.stringify(bodyPayload)
          });

          alert(activeDoc ? 'Document updated successfully!' : 'Document published successfully!');
          
          // Re-load list
          await loadDocuments();

          // Set active doc to the updated one
          loadDoc(targetPath, result.content.sha, filename, collection);

        } catch (error) {
          alert(`Error saving document: ${error.message}`);
        } finally {
          saveSpinner.classList.add('hidden');
          saveBtn.disabled = false;
        }
      });

      // Preview toggle
      let previewMode = false;
      previewToggle.addEventListener('click', () => {
        previewMode = !previewMode;
        if (previewMode) {
          previewToggle.textContent = 'EDITOR';
          editorForm.classList.add('hidden');
          previewPane.classList.remove('hidden');
          renderPreview();
        } else {
          closePreview();
        }
      });

      function closePreview() {
        previewMode = false;
        previewToggle.textContent = 'PREVIEW';
        editorForm.classList.remove('hidden');
        previewPane.classList.add('hidden');
      }

      function renderPreview() {
        document.getElementById('prev-title').textContent = titleInput.value;
        
        // Simple client-side Markdown rendering fallback
        const rawMarkdown = bodyInput.value;
        const html = rawMarkdown
          .replace(/^## (.*$)/gim, '<h2 class="font-serif font-bold text-xl mt-6 border-b border-[var(--color-border)] pb-2">$1</h2>')
          .replace(/^### (.*$)/gim, '<h3 class="font-serif font-bold text-lg mt-4">$1</h3>')
          .replace(/^# (.*$)/gim, '<h1 class="font-serif font-bold text-3xl mt-8 mb-4">$1</h1>')
          .replace(/^\> (.*$)/gim, '<blockquote class="border-l-4 border-[var(--color-border-hover)] pl-4 italic my-4">$1</blockquote>')
          .replace(/\*\*(.*)\*\*/gim, '<strong>$1</strong>')
          .replace(/\*(.*)\*/gim, '<em>$1</em>')
          .replace(/\[(.*?)\]\((.*?)\)/gim, "<a href='$2' class='underline hover:opacity-85' target='_blank'>$1</a>")
          .replace(/\n$/gim, '<br />')
          .split('\n\n').map(p => p.trim() ? `<p>${p}</p>` : '').join('');

        document.getElementById('prev-content').innerHTML = html;
      }

      // Drag and Drop Image Upload directly to GitHub public/images/
      const editorDropzone = document.getElementById('doc-body');

      editorDropzone.addEventListener('dragenter', (e) => {
        e.preventDefault();
        dragOverlay.classList.remove('hidden');
      });

      dragOverlay.addEventListener('dragleave', () => {
        dragOverlay.classList.add('hidden');
      });

      overlay.addEventListener('dragover', (e) => {
        e.preventDefault();
      });

      dragOverlay.addEventListener('drop', async (e) => {
        e.preventDefault();
        dragOverlay.classList.add('hidden');

        const files = e.dataTransfer.files;
        if (files.length === 0) return;

        const file = files[0];
        if (!file.type.startsWith('image/')) {
          alert('Only image uploads are supported.');
          return;
        }

        const confirmUpload = confirm(`Do you want to upload and commit ${file.name} to the repository?`);
        if (!confirmUpload) return;

        // Convert image file to base64
        const reader = new FileReader();
        reader.onload = async () => {
          const base64Content = reader.result.split(',')[1];
          const filename = `${Date.now()}-${file.name.replace(/[^a-zA-Z0-9.-]/g, '_')}`;
          const path = `public/images/${filename}`;

          saveSpinner.classList.remove('hidden');
          saveBtn.disabled = true;

          try {
            await fetchGitHub(`contents/${path}`, {
              method: 'PUT',
              body: JSON.stringify({
                message: `Upload asset: ${filename}`,
                content: base64Content,
                branch: 'main'
              })
            });

            // Insert link in cursor position
            const markdownLink = `\n![${file.name}](/images/${filename})\n`;
            const startPos = editorDropzone.selectionStart;
            const endPos = editorDropzone.selectionEnd;
            editorDropzone.value = editorDropzone.value.substring(0, startPos) +
              markdownLink +
              editorDropzone.value.substring(endPos, editorDropzone.value.length);
            
            alert('Image uploaded and committed successfully!');

          } catch (err) {
            alert(`Failed to upload image: ${err.message}`);
          } finally {
            saveSpinner.classList.add('hidden');
            saveBtn.disabled = false;
          }
        };

        reader.readAsDataURL(file);
      });

      // Init on load
      document.addEventListener('astro:page-load', init);
      init();
    })();
  </script>
</BaseLayout>
