---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';
import PostCard from '../../../components/PostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  const activePosts = posts.filter(p => !p.data.draft);
  const tags = [...new Set(activePosts.flatMap(p => p.data.tags || []))];

  return tags.map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: activePosts
        .filter(p => p.data.tags?.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;

function getReadingTime(text: string): string {
  const words = text?.split(/\s+/).length || 0;
  return `${Math.ceil(words / 200)} min read`;
}
---

<PageLayout
  title={`Posts Tagged: #${tag}`}
  description={`Browse all articles categorized under tag #${tag}.`}
  breadcrumbs={[
    { label: 'Writing', href: '/writing' },
    { label: `#${tag}`, href: `/writing/tags/${tag}` }
  ]}
>
  <div class="mb-8">
    <a href="/writing" class="text-sm text-[var(--color-accent)] hover:underline flex items-center gap-1">
      ← Back to all articles
    </a>
  </div>

  <div class="divide-y divide-[var(--color-border)]">
    {posts.map(post => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        slug={post.id}
        date={post.data.date}
        readingTime={getReadingTime(post.body || '')}
        tags={post.data.tags}
        category={post.data.category}
      />
    ))}
  </div>
</PageLayout>
