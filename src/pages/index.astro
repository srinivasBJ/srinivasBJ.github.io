---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allBlog = await getCollection('blog');
const allLab = await getCollection('lab');
const allProjects = await getCollection('projects');

// Filters & Sorts
const pinnedPosts = allBlog
  .filter(p => !p.data.draft && p.data.pinned)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latestPosts = allBlog
  .filter(p => !p.data.draft && !p.data.pinned)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const recentLab = allLab
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0))
  .slice(0, 2);

const recentActivity = [
  ...allBlog.filter(p => !p.data.draft).map(p => ({
    date: p.data.date,
    type: 'Article',
    title: p.data.title,
    href: `/blog/${p.id}`
  })),
  ...allLab.filter(n => !n.data.draft).map(n => ({
    date: n.data.date,
    type: 'Lab Note',
    title: n.data.title,
    href: `/lab/${n.id}`
  }))
]
.sort((a, b) => b.date.valueOf() - a.date.valueOf())
.slice(0, 5);

function getReadingTime(text: string): string {
  const words = text?.split(/\s+/).length || 0;
  return `${Math.ceil(words / 200)} min read`;
}
---

<BaseLayout title="srinivasBJ">
  <div class="max-w-3xl mx-auto px-6 py-12 md:py-20 space-y-20 animate-fade-in">
    
    <!-- Wordmark header / Intro -->
    <header class="border-b border-[var(--color-border)] pb-8">
      <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-[var(--color-text)]">
        srinivasBJ
      </h1>
      <p class="mt-4 text-base md:text-lg text-[var(--color-text-secondary)] font-normal leading-relaxed max-w-2xl">
        A personal space for publishing engineering ideas, system designs, digital garden logs, and cataloging books.
      </p>
    </header>

    <!-- Recent Activity -->
    {recentActivity.length > 0 && (
      <section class="space-y-6">
        <h2 class="text-xs font-mono text-[var(--color-text-tertiary)] uppercase tracking-wider border-b border-[var(--color-border)] pb-2">
          Recent Activity
        </h2>
        <ul class="space-y-4">
          {recentActivity.map(act => (
            <li class="flex items-baseline gap-4 text-sm">
              <span class="text-xs font-mono text-[var(--color-text-tertiary)] shrink-0 w-28">
                {new Date(act.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
              <span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-[var(--color-bg-secondary)] border border-[var(--color-border)] text-[var(--color-text-secondary)] shrink-0 select-none">
                {act.type}
              </span>
              <a href={act.href} class="text-[var(--color-text)] hover:text-[var(--color-accent-primary)] hover:underline transition-colors truncate">
                {act.title}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Pinned Posts -->
    {pinnedPosts.length > 0 && (
      <section class="space-y-6">
        <h2 class="text-xs font-mono text-[var(--color-text-tertiary)] uppercase tracking-wider border-b border-[var(--color-border)] pb-2">
          Pinned Articles
        </h2>
        <div class="divide-y divide-[var(--color-border)]">
          {pinnedPosts.map(post => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              slug={post.id}
              date={post.data.date}
              readingTime={getReadingTime(post.body || '')}
              categories={post.data.categories}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Latest Blog Articles -->
    <section class="space-y-6">
      <div class="flex items-baseline justify-between border-b border-[var(--color-border)] pb-2">
        <h2 class="text-xs font-mono text-[var(--color-text-tertiary)] uppercase tracking-wider">
          Latest Articles
        </h2>
        <a href="/blog" class="text-xs font-mono text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors">
          VIEW ALL →
        </a>
      </div>
      {latestPosts.length > 0 ? (
        <div class="divide-y divide-[var(--color-border)]">
          {latestPosts.map(post => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              slug={post.id}
              date={post.data.date}
              readingTime={getReadingTime(post.body || '')}
              categories={post.data.categories}
            />
          ))}
        </div>
      ) : (
        <p class="text-sm text-[var(--color-text-tertiary)] italic">No articles published yet.</p>
      )}
    </section>

    <!-- Lab Notes Teaser -->
    <section class="space-y-6">
      <div class="flex items-baseline justify-between border-b border-[var(--color-border)] pb-2">
        <h2 class="text-xs font-mono text-[var(--color-text-tertiary)] uppercase tracking-wider">
          Recent Lab Notes
        </h2>
        <a href="/lab" class="text-xs font-mono text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors">
          EXPLORE GARDEN →
        </a>
      </div>
      {recentLab.length > 0 ? (
        <div class="space-y-4">
          {recentLab.map(note => (
            <a
              href={`/lab/${note.id}`}
              class="block p-4 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-border-hover)] transition-all duration-150 group"
            >
              <div class="flex items-center justify-between text-xs font-mono text-[var(--color-text-tertiary)] mb-2">
                <span>{new Date(note.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                <span class="text-[10px] uppercase tracking-wider px-1 rounded bg-[var(--color-bg-secondary)] border border-[var(--color-border)] text-[var(--color-text-secondary)]">{note.data.category}</span>
              </div>
              <h3 class="font-serif font-bold text-base text-[var(--color-text)] group-hover:text-[var(--color-accent-primary)] transition-colors">
                {note.data.title}
              </h3>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-sm text-[var(--color-text-tertiary)] italic">No lab notes logged yet.</p>
      )}
    </section>

    <!-- Featured Projects -->
    <section class="space-y-6">
      <div class="flex items-baseline justify-between border-b border-[var(--color-border)] pb-2">
        <h2 class="text-xs font-mono text-[var(--color-text-tertiary)] uppercase tracking-wider">
          Featured Projects
        </h2>
        <a href="/projects" class="text-xs font-mono text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors">
          ALL PROJECTS →
        </a>
      </div>
      {featuredProjects.length > 0 ? (
        <div class="grid sm:grid-cols-2 gap-6">
          {featuredProjects.map(proj => (
            <ProjectCard
              title={proj.data.title}
              description={proj.data.description}
              slug={proj.id}
              tags={proj.data.tags}
              timeline={proj.data.timeline}
              featured={proj.data.featured}
              github={proj.data.github}
            />
          ))}
        </div>
      ) : (
        <p class="text-sm text-[var(--color-text-tertiary)] italic">No featured projects found.</p>
      )}
    </section>

    <!-- Reach Out -->
    <section class="space-y-10 pt-4">
      <div>
        <h2 class="font-serif text-3xl md:text-[2.75rem] lg:text-5xl font-bold tracking-tight text-[var(--color-text)] leading-[1.15]">
          If you got this far, reach out.
        </h2>
        <p class="mt-4 text-sm md:text-[15px] text-[var(--color-text-secondary)] max-w-md leading-relaxed">
          Open to internships, collaborations, and problems worth solving.
        </p>
      </div>

      <div class="grid md:grid-cols-[1fr_1.2fr] gap-12 md:gap-16">
        <!-- Contact Links -->
        <div class="divide-y divide-[var(--color-border)] border-t border-b border-[var(--color-border)] h-fit">
          <a
            href="mailto:ssai603174@gmail.com"
            class="flex items-center gap-3.5 py-4 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors group"
          >
            <!-- Gmail icon -->
            <svg class="w-[18px] h-[18px] shrink-0" viewBox="0 0 24 24" fill="none">
              <path d="M20 18h-2V9.25L12 13 6 9.25V18H4V6h1.2l6.8 4.25L18.8 6H20v12z" fill="currentColor"/>
              <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
            </svg>
            <span class="font-medium">Email</span>
            <span class="ml-auto text-xs font-mono text-[var(--color-text-tertiary)]">ssai603174@gmail.com</span>
          </a>

          <a
            href="https://github.com/srinivasBJ"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3.5 py-4 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors group"
          >
            <svg class="w-[18px] h-[18px] shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z" clip-rule="evenodd" />
            </svg>
            <span class="font-medium">GitHub</span>
            <span class="ml-auto text-xs font-mono text-[var(--color-text-tertiary)]">srinivasBJ</span>
          </a>
        </div>

        <!-- Contact Form -->
        <form
          action="https://formspree.io/f/placeholder"
          method="POST"
          class="space-y-4"
        >
          <div class="grid grid-cols-2 gap-4">
            <input
              type="text"
              name="name"
              placeholder="Name"
              required
              class="w-full px-4 py-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm text-[var(--color-text)] placeholder:text-[var(--color-text-tertiary)] focus:outline-none focus:border-[var(--color-border-hover)] focus:ring-1 focus:ring-[var(--color-border-hover)] transition-colors"
            />
            <input
              type="email"
              name="email"
              placeholder="Email"
              required
              class="w-full px-4 py-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm text-[var(--color-text)] placeholder:text-[var(--color-text-tertiary)] focus:outline-none focus:border-[var(--color-border-hover)] focus:ring-1 focus:ring-[var(--color-border-hover)] transition-colors"
            />
          </div>
          <textarea
            name="message"
            placeholder="What's on your mind?"
            rows="5"
            required
            class="w-full px-4 py-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm text-[var(--color-text)] placeholder:text-[var(--color-text-tertiary)] focus:outline-none focus:border-[var(--color-border-hover)] focus:ring-1 focus:ring-[var(--color-border-hover)] transition-colors resize-none"
          ></textarea>
          <button
            type="submit"
            class="px-6 py-2.5 rounded-lg border border-[var(--color-border)] text-sm font-medium text-[var(--color-text)] hover:bg-[var(--color-surface-hover)] hover:border-[var(--color-border-hover)] transition-all duration-150 cursor-pointer"
          >
            Send message
          </button>
        </form>
      </div>
    </section>

  </div>
</BaseLayout>
