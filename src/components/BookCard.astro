---
interface Props {
  title: string;
  author: string;
  category: string;
  description: string;
  rating?: number;
  url?: string;
}

const { title, author, category, description, rating, url } = Astro.props;

// Generate star display (1-5)
const maxStars = 5;
const filledStars = rating ? Math.min(Math.max(Math.round(rating), 0), maxStars) : 0;
const emptyStars = maxStars - filledStars;
---

<div class="p-5 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-border-hover)] transition-colors duration-200">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      {url ? (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-base font-semibold text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors duration-200 inline-flex items-center gap-1.5"
        >
          {title}
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      ) : (
        <h3 class="text-base font-semibold text-[var(--color-text)]">
          {title}
        </h3>
      )}
      <p class="text-sm text-[var(--color-text-secondary)] mt-0.5">
        by {author}
      </p>
    </div>

    <!-- Category badge -->
    <span class="shrink-0 text-xs font-medium px-2.5 py-1 rounded-full bg-[var(--color-bg-secondary)] text-[var(--color-text-secondary)]">
      {category}
    </span>
  </div>

  <!-- Star Rating -->
  {rating !== undefined && (
    <div class="flex items-center gap-0.5 mt-3" aria-label={`Rating: ${filledStars} out of ${maxStars} stars`}>
      {Array.from({ length: filledStars }).map(() => (
        <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
      {Array.from({ length: emptyStars }).map(() => (
        <svg class="w-4 h-4 text-[var(--color-text-tertiary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
        </svg>
      ))}
    </div>
  )}

  <!-- Description -->
  <p class="text-sm text-[var(--color-text-secondary)] mt-3 leading-relaxed line-clamp-3">
    {description}
  </p>
</div>
