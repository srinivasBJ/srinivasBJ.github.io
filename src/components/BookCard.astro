---
interface Props {
  title: string;
  author: string;
  category: string;
  description: string;
  url?: string;
  tags?: string[];
}

const { title, author, category, description, url, tags } = Astro.props;
---

<div class="p-8 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-border-hover)] transition-all duration-200 flex flex-col justify-between h-full relative group">
  <div>
    <div class="flex items-center justify-between gap-2 mb-4">
      <span class="text-[10px] font-mono uppercase tracking-wider px-1.5 py-0.5 rounded bg-[var(--color-bg-secondary)] text-[var(--color-text-secondary)] border border-[var(--color-border)]">
        {category}
      </span>
      {url && (
        <span class="text-xs text-[var(--color-text-tertiary)] group-hover:text-[var(--color-text)] transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </span>
      )}
    </div>

    <h3 class="font-display text-xl font-bold text-[var(--color-heading)] leading-snug">
      {url ? (
        <a href={url} target="_blank" rel="noopener noreferrer" class="hover:underline focus:outline-none">
          {title}
        </a>
      ) : (
        title
      )}
    </h3>
    <p class="text-xs font-mono text-[var(--color-text-secondary)] mt-1">
      {author}
    </p>

    <p class="text-sm text-[var(--color-text-secondary)] mt-4 leading-relaxed line-clamp-3">
      {description}
    </p>
  </div>

  {tags && tags.length > 0 && (
    <div class="mt-6 pt-3 border-t border-[var(--color-border)] flex flex-wrap gap-1">
      {tags.map((tag) => (
        <span class="text-[9px] font-mono px-1.5 py-0.5 rounded bg-[var(--color-bg-secondary)] text-[var(--color-text-tertiary)]">
          #{tag}
        </span>
      ))}
    </div>
  )}
</div>
