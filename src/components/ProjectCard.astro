---
interface Props {
  title: string;
  description: string;
  slug: string;
  tags: string[];
  timeline?: string;
  featured?: boolean;
  github?: string;
  variant?: 'hero' | 'card';
}

const { title, description, slug, tags, timeline, featured, github, variant = 'card' } = Astro.props;

const isHero = variant === 'hero';
---

{isHero ? (
  <a href={`/projects/${slug}`} class="block group">
    <div class="relative p-8 md:p-10 rounded-2xl bg-[#111] dark:bg-[#111] border border-[#222] dark:border-[#222] overflow-hidden transition-all duration-300 hover:border-[#333]">
      <!-- Subtle gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-br from-[#1a1a2e]/40 via-transparent to-[#16213e]/30 rounded-2xl pointer-events-none"></div>

      <div class="relative z-10">
        <!-- Badge -->
        <span class="inline-block text-[11px] font-mono uppercase tracking-wider px-2 py-0.5 rounded-full bg-[#1f1f2e] text-[#9e8cfc] border border-[#2a2a3e] mb-5">
          Open Source
        </span>

        <h3 class="font-serif text-2xl md:text-3xl font-bold text-[#f0ecdf] mb-3 tracking-tight">
          {title}
        </h3>

        <p class="text-sm md:text-[15px] text-[#a09a8c] leading-relaxed max-w-xl mb-8">
          {description}
        </p>

        <div class="flex items-center justify-between">
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="text-[11px] font-mono px-2.5 py-1 rounded-full bg-[#1a1a24] text-[#8a8474] border border-[#262630]">
                {tag}
              </span>
            ))}
          </div>

          <div class="flex items-center gap-3">
            {github && (
              <svg class="w-5 h-5 text-[#706b5e] hover:text-[#f0ecdf] transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z" clip-rule="evenodd" />
              </svg>
            )}
            <span class="inline-flex items-center gap-1.5 text-sm font-medium text-[#f0ecdf] border border-[#333] rounded-full px-4 py-1.5 group-hover:bg-[#f0ecdf] group-hover:text-[#111] transition-all duration-200">
              View project
              <svg class="w-3.5 h-3.5 transform group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </span>
          </div>
        </div>
      </div>
    </div>
  </a>
) : (
  <a href={`/projects/${slug}`} class="block group">
    <div class="p-6 md:p-7 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-border-hover)] transition-all duration-200 flex flex-col justify-between h-full">
      <div>
        <div class="flex items-center justify-between gap-2 mb-4">
          <!-- Badge -->
          {featured ? (
            <span class="inline-flex items-center gap-1 text-[11px] font-mono text-emerald-600 dark:text-emerald-400">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
              Open Source
            </span>
          ) : (
            <span class="text-[11px] font-mono text-[var(--color-text-tertiary)]">
              {timeline}
            </span>
          )}

          <!-- GitHub Icon -->
          {github && (
            <svg class="w-4 h-4 text-[var(--color-text-tertiary)] group-hover:text-[var(--color-text)] transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z" clip-rule="evenodd" />
            </svg>
          )}
        </div>

        <h3 class="font-serif text-lg font-bold text-[var(--color-text)] group-hover:text-[var(--color-accent-primary)] transition-colors mb-2">
          {title}
        </h3>

        <p class="text-[13px] text-[var(--color-text-secondary)] leading-relaxed line-clamp-3">
          {description}
        </p>
      </div>

      <div class="mt-5 pt-4 border-t border-[var(--color-border)] flex items-center justify-between">
        <div class="flex flex-wrap gap-1.5">
          {tags.slice(0, 2).map((tag) => (
            <span class="text-[10px] font-mono px-2 py-0.5 rounded-full bg-[var(--color-bg-secondary)] text-[var(--color-text-tertiary)] border border-[var(--color-border)]">
              {tag}
            </span>
          ))}
          {tags.length > 2 && (
            <span class="text-[10px] font-mono px-2 py-0.5 text-[var(--color-text-tertiary)]">
              +{tags.length - 2}
            </span>
          )}
        </div>

        <span class="inline-flex items-center gap-1 text-xs font-medium text-[var(--color-text-secondary)] group-hover:text-[var(--color-accent-primary)] transition-colors">
          View
          <svg class="w-3.5 h-3.5 transform group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </span>
      </div>
    </div>
  </a>
)}
