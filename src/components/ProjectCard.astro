---
interface Props {
  title: string;
  description: string;
  slug: string;
  tags: string[];
  featured?: boolean;
}

const { title, description, slug, tags, featured = false } = Astro.props;
---

<a
  href={`/projects/${slug}`}
  class:list={[
    'group block p-6 rounded-xl border bg-[var(--color-surface)] hover-lift transition-all duration-200',
    featured
      ? 'border-[var(--color-accent)]/30 hover:border-[var(--color-accent)]'
      : 'border-[var(--color-border)] hover:border-[var(--color-border-hover)]',
  ]}
>
  {featured && (
    <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full bg-[var(--color-accent-subtle)] text-[var(--color-accent)] mb-3">
      Featured
    </span>
  )}

  <div class="flex items-start justify-between gap-4">
    <h3 class="text-lg font-semibold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-200">
      {title}
    </h3>
    <!-- Arrow icon -->
    <svg
      class="w-5 h-5 shrink-0 mt-0.5 text-[var(--color-text-tertiary)] group-hover:text-[var(--color-accent)] group-hover:translate-x-1 transition-all duration-200"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
    </svg>
  </div>

  <p class="text-[var(--color-text-secondary)] mt-2 line-clamp-2 text-sm leading-relaxed">
    {description}
  </p>

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mt-4">
      {tags.map((tag) => (
        <span class="text-xs px-2 py-1 rounded-full bg-[var(--color-bg-secondary)] text-[var(--color-text-secondary)]">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
