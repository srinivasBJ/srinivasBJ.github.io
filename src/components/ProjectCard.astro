---
interface Props {
  title: string;
  description: string;
  slug: string;
  tags: string[];
  timeline?: string;
  featured?: boolean;
}

const { title, description, slug, tags, timeline } = Astro.props;
---

<div class="p-8 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-border-hover)] transition-all duration-200 group relative flex flex-col justify-between">
  <div>
    <div class="flex items-center justify-between gap-2 mb-4">
      {timeline && (
        <span class="text-xs font-mono text-[var(--color-text-tertiary)]">{timeline}</span>
      )}
      <span class="text-[10px] font-mono uppercase tracking-wider px-1.5 py-0.5 rounded bg-[var(--color-bg-secondary)] text-[var(--color-text-secondary)] border border-[var(--color-border)]">
        Project
      </span>
    </div>

    <h3 class="font-serif text-xl font-bold text-[var(--color-text)] group-hover:text-[var(--color-accent-primary)] transition-colors">
      <a href={`/projects/${slug}`} class="focus:outline-none">
        {title}
        <span class="absolute inset-0" aria-hidden="true"></span>
      </a>
    </h3>

    <p class="text-sm text-[var(--color-text-secondary)] mt-2 leading-relaxed line-clamp-3">
      {description}
    </p>
  </div>

  <div class="mt-6 pt-4 border-t border-[var(--color-border)] flex items-center justify-between">
    <div class="flex flex-wrap gap-1">
      {tags.slice(0, 2).map((tag) => (
        <span class="text-[9px] font-mono px-1.5 py-0.5 rounded bg-[var(--color-bg-secondary)] text-[var(--color-text-tertiary)]">
          {tag}
        </span>
      ))}
      {tags.length > 2 && (
        <span class="text-[9px] font-mono px-1.5 py-0.5 text-[var(--color-text-tertiary)]">
          +{tags.length - 2}
        </span>
      )}
    </div>
    
    <svg class="w-4 h-4 text-[var(--color-text-tertiary)] group-hover:text-[var(--color-text)] transform group-hover:translate-x-0.5 transition-all duration-150" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
    </svg>
  </div>
</div>
