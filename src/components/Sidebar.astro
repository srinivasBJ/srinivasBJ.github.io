---
import ThemeToggle from './ThemeToggle.astro';

interface NavLink {
  label: string;
  href: string;
  icon: string;
}

// Icon paths (Heroicons-style, 24x24, stroke)
const navLinks: NavLink[] = [
  { label: 'Home', href: '/', icon: 'M2.25 12l8.954-8.955a1.5 1.5 0 012.122 0L22.28 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75' },
  { label: 'Blog', href: '/blog', icon: 'M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5' },
  { label: 'Lab', href: '/lab', icon: 'M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21a48.25 48.25 0 01-8.135-.687c-1.718-.293-2.3-2.379-1.067-3.61L5 14.5' },
  { label: 'Projects', href: '/projects', icon: 'M2.25 7.125C2.25 6.504 2.754 6 3.375 6h6c.621 0 1.125.504 1.125 1.125v3.75c0 .621-.504 1.125-1.125 1.125h-6a1.125 1.125 0 01-1.125-1.125v-3.75zM14.25 8.625c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v8.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-8.25zM3.75 16.125c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-2.25z' },
  { label: 'Reading', href: '/reading', icon: 'M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25' },
];

const currentPath = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<div class="flex flex-col h-full justify-between">
  <div class="space-y-7">
    <!-- Wordmark / Logo + Theme Toggle -->
    <div class="flex items-start justify-between gap-4">
      <a href="/" class="group flex items-center gap-2.5 no-underline">
        <span class="grid place-items-center w-8 h-8 rounded-lg text-sm font-bold text-white shrink-0"
          style="background: linear-gradient(140deg, var(--color-accent-primary), color-mix(in srgb, var(--color-accent-primary) 55%, #000)); box-shadow: 0 4px 14px -4px var(--color-accent-glow);">
          s
        </span>
        <span class="flex flex-col leading-none">
          <span class="font-display text-[15px] font-bold tracking-tight text-[var(--color-text)] group-hover:text-[var(--color-accent-primary)] transition-colors">
            srinivasBJ
          </span>
          <span class="text-[9px] font-mono text-[var(--color-text-tertiary)] uppercase tracking-[0.18em] mt-1">
            Living Notes
          </span>
        </span>
      </a>
      <ThemeToggle />
    </div>

    <!-- Search Button Trigger -->
    <div>
      <button
        onclick="document.dispatchEvent(new CustomEvent('toggle-command-palette'))"
        class="w-full flex items-center gap-2 px-2.5 py-2 rounded-lg text-xs text-[var(--color-text-tertiary)] border border-[var(--color-border)] hover:border-[var(--color-border-hover)] hover:bg-[var(--color-surface-hover)] transition-all duration-150 cursor-pointer"
        aria-label="Search"
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
        <span>Search…</span>
        <kbd class="ml-auto text-[9px] font-mono px-1 py-0.5 rounded bg-[var(--color-bg-tertiary)] border border-[var(--color-border)] text-[var(--color-text-tertiary)]">
          ⌘K
        </kbd>
      </button>
    </div>

    <!-- Main Navigation Links -->
    <nav class="flex flex-col gap-0.5" aria-label="Sidebar navigation">
      {navLinks.map((link) => {
        const active = isActive(link.href);
        return (
          <a
            href={link.href}
            class:list={[
              'relative flex items-center gap-3 pl-3.5 pr-3 py-2 rounded-lg text-sm font-medium transition-all duration-150 no-underline',
              active
                ? 'text-[var(--color-text)] bg-[var(--color-surface-hover)]'
                : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-hover)]',
            ]}
            aria-current={active ? 'page' : undefined}
          >
            {active && (
              <span class="absolute left-0 top-1/2 -translate-y-1/2 h-4 w-[3px] rounded-full bg-[var(--color-accent-primary)]"></span>
            )}
            <svg class:list={['w-[17px] h-[17px] shrink-0 transition-colors', active ? 'text-[var(--color-accent-primary)]' : 'text-[var(--color-text-tertiary)] group-hover:text-[var(--color-text-secondary)]']} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.6">
              <path stroke-linecap="round" stroke-linejoin="round" d={link.icon} />
            </svg>
            {link.label}
          </a>
        );
      })}
    </nav>
  </div>

  <!-- Bottom Details: GitHub Link -->
  <div class="pt-6 border-t border-[var(--color-border)]">
    <a
      href="https://github.com/srinivasBJ"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-hover)] transition-all duration-150 no-underline"
    >
      <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z" clip-rule="evenodd" />
      </svg>
      <span class="font-medium">GitHub</span>
    </a>
  </div>
</div>
