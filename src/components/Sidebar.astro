---
import ThemeToggle from './ThemeToggle.astro';

interface NavLink {
  label: string;
  href: string;
}

const navLinks: NavLink[] = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: 'Lab', href: '/lab' },
  { label: 'Projects', href: '/projects' },
  { label: 'Reading', href: '/reading' },
];

const currentPath = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<div class="flex flex-col h-full justify-between">
  <div class="space-y-8">
    <!-- Wordmark / Logo + Theme Toggle -->
    <div class="flex items-start justify-between gap-4">
      <div>
        <a
          href="/"
          class="font-serif text-xl font-bold tracking-tight text-[var(--color-text)] hover:opacity-85 transition-opacity"
        >
          srinivasBJ
        </a>
        <span class="block text-[10px] font-mono text-[var(--color-text-tertiary)] uppercase tracking-wider mt-1">
          Living Notes
        </span>
      </div>
      <ThemeToggle />
    </div>

    <!-- Search Button Trigger -->
    <div>
      <button
        onclick="document.dispatchEvent(new CustomEvent('toggle-command-palette'))"
        class="w-full flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-[var(--color-text-secondary)] border border-[var(--color-border)] hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-secondary)] transition-all duration-150 cursor-pointer"
        aria-label="Search pages"
      >
        <svg class="w-4 h-4 text-[var(--color-text-tertiary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
        <span class="text-xs text-[var(--color-text-tertiary)]">Search site…</span>
        <kbd class="ml-auto text-[10px] font-mono px-1.5 py-0.5 rounded bg-[var(--color-bg-tertiary)] border border-[var(--color-border)] text-[var(--color-text-tertiary)]">
          ⌘K
        </kbd>
      </button>
    </div>

    <!-- Main Navigation Links -->
    <nav class="flex flex-col gap-1" aria-label="Sidebar navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'px-3 py-2 rounded-lg text-sm font-medium transition-colors duration-150',
            isActive(link.href)
              ? 'text-[var(--color-text)] bg-[var(--color-bg-secondary)] font-semibold'
              : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-hover)]',
          ]}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>

  <!-- Bottom Details: GitHub Link -->
  <div class="pt-6 border-t border-[var(--color-border)]">
    <!-- GitHub Profile -->
    <a
      href="https://github.com/srinivasBJ"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-hover)] transition-all duration-150"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z" clip-rule="evenodd" />
      </svg>
      <span class="font-medium">GitHub</span>
    </a>
  </div>
</div>
