---
interface NavItem {
  title: string;
  slug: string;
}

interface Props {
  prev?: NavItem | null;
  next?: NavItem | null;
}

const { prev = null, next = null } = Astro.props;
---

{(prev || next) && (
  <nav
    class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-16 pt-8 border-t border-[var(--color-border)]"
    aria-label="Previous and next articles"
  >
    <!-- Previous -->
    {prev ? (
      <a
        href={prev.slug}
        class="group flex items-center gap-4 p-4 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-border-hover)] bg-[var(--color-surface)] hover:bg-[var(--color-surface-hover)] transition-all duration-200"
      >
        <svg
          class="w-5 h-5 shrink-0 text-[var(--color-text-tertiary)] group-hover:text-[var(--color-accent)] group-hover:-translate-x-1 transition-all duration-200"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        <div class="min-w-0">
          <span class="text-xs text-[var(--color-text-tertiary)] font-medium">Previous</span>
          <p class="text-sm font-semibold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-200 truncate">
            {prev.title}
          </p>
        </div>
      </a>
    ) : (
      <div />
    )}

    <!-- Next -->
    {next ? (
      <a
        href={next.slug}
        class="group flex items-center justify-end gap-4 p-4 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-border-hover)] bg-[var(--color-surface)] hover:bg-[var(--color-surface-hover)] transition-all duration-200 text-right"
      >
        <div class="min-w-0">
          <span class="text-xs text-[var(--color-text-tertiary)] font-medium">Next</span>
          <p class="text-sm font-semibold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-200 truncate">
            {next.title}
          </p>
        </div>
        <svg
          class="w-5 h-5 shrink-0 text-[var(--color-text-tertiary)] group-hover:text-[var(--color-accent)] group-hover:translate-x-1 transition-all duration-200"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    ) : (
      <div />
    )}
  </nav>
)}
