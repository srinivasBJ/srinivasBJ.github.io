---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// Filter to only h2 and h3
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);

// Group h3s under their preceding h2
interface TocEntry {
  slug: string;
  text: string;
  children: { slug: string; text: string }[];
}

const toc: TocEntry[] = [];
for (const heading of filtered) {
  if (heading.depth === 2) {
    toc.push({ slug: heading.slug, text: heading.text, children: [] });
  } else if (heading.depth === 3 && toc.length > 0) {
    toc[toc.length - 1].children.push({ slug: heading.slug, text: heading.text });
  }
}
---

{toc.length > 0 && (
  <nav class="sticky top-24" aria-label="Table of contents">
    <h4 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-tertiary)] mb-3">
      On this page
    </h4>
    <ul class="space-y-1 text-sm" id="toc-list">
      {toc.map((entry) => (
        <li>
          <a
            href={`#${entry.slug}`}
            class="toc-link block py-1 text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors duration-200 border-l-2 border-transparent pl-3 hover:border-[var(--color-accent)]"
            data-slug={entry.slug}
          >
            {entry.text}
          </a>
          {entry.children.length > 0 && (
            <ul class="ml-3 space-y-1">
              {entry.children.map((child) => (
                <li>
                  <a
                    href={`#${child.slug}`}
                    class="toc-link block py-1 text-[var(--color-text-tertiary)] hover:text-[var(--color-accent)] transition-colors duration-200 border-l-2 border-transparent pl-3 hover:border-[var(--color-accent)] text-xs"
                    data-slug={child.slug}
                  >
                    {child.text}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </nav>
)}

<script is:inline>
  (function () {
    let observer;

    function initTOC() {
      // Disconnect existing observer if any
      if (observer) {
        observer.disconnect();
      }

      const tocLinks = document.querySelectorAll('.toc-link');
      if (!tocLinks.length) return;

      const slugs = Array.from(tocLinks).map((link) => link.getAttribute('data-slug'));
      const headingEls = slugs
        .map((slug) => document.getElementById(slug))
        .filter(Boolean);

      if (!headingEls.length) return;

      const ACTIVE_CLASSES = ['text-[var(--color-accent)]', 'border-[var(--color-accent)]'];
      const INACTIVE_TEXT_CLASS = 'text-[var(--color-text-secondary)]';
      const INACTIVE_CHILD_CLASS = 'text-[var(--color-text-tertiary)]';

      function setActive(slug) {
        tocLinks.forEach((link) => {
          const linkSlug = link.getAttribute('data-slug');
          ACTIVE_CLASSES.forEach((cls) => link.classList.remove(cls));
          link.classList.remove('border-transparent');

          if (linkSlug === slug) {
            ACTIVE_CLASSES.forEach((cls) => link.classList.add(cls));
            link.classList.remove(INACTIVE_TEXT_CLASS);
            link.classList.remove(INACTIVE_CHILD_CLASS);
          } else {
            link.classList.add('border-transparent');
          }
        });
      }

      observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              setActive(entry.target.id);
              break;
            }
          }
        },
        { rootMargin: '-80px 0px -70% 0px', threshold: 0 }
      );

      headingEls.forEach((el) => observer.observe(el));
    }

    document.addEventListener('astro:page-load', initTOC);
    initTOC();
  })();
</script>
