---
// CopyCodeButton: injects a copy-to-clipboard button into every <pre> block on the page.
// Include this component once in your layout.
---

<script is:inline>
  (function () {
    function addCopyButtons() {
      const pres = document.querySelectorAll('pre');
      pres.forEach((pre) => {
        // Skip if already processed
        if (pre.parentElement && pre.parentElement.classList.contains('code-wrapper')) return;

        // Wrap pre in a relative container
        const wrapper = document.createElement('div');
        wrapper.className = 'code-wrapper relative';
        pre.parentNode.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);

        // Create copy button
        const button = document.createElement('button');
        button.type = 'button';
        button.className =
          'absolute top-3 right-3 p-1.5 rounded-md bg-[var(--color-surface-hover)] text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)] transition-colors duration-200 opacity-0 group-hover:opacity-100';
        button.setAttribute('aria-label', 'Copy code');

        // Make the wrapper a group so the button can respond to hover
        wrapper.classList.add('group');

        // Clipboard icon
        button.innerHTML = `
          <svg class="copy-icon w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />
          </svg>
          <svg class="check-icon w-4 h-4 hidden text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
          </svg>
        `;

        // Show button on wrapper hover
        wrapper.addEventListener('mouseenter', () => {
          button.style.opacity = '1';
        });
        wrapper.addEventListener('mouseleave', () => {
          button.style.opacity = '0';
        });

        // Copy handler
        button.addEventListener('click', async () => {
          const code = pre.querySelector('code');
          const text = code ? code.textContent : pre.textContent;

          try {
            await navigator.clipboard.writeText(text || '');
            const copyIcon = button.querySelector('.copy-icon');
            const checkIcon = button.querySelector('.check-icon');
            if (copyIcon && checkIcon) {
              copyIcon.classList.add('hidden');
              checkIcon.classList.remove('hidden');
              setTimeout(() => {
                copyIcon.classList.remove('hidden');
                checkIcon.classList.add('hidden');
              }, 2000);
            }
          } catch {
            // Fallback: do nothing silently
          }
        });

        wrapper.appendChild(button);
      });
    }

    // Run on page load and transition
    document.addEventListener('astro:page-load', addCopyButtons);
    addCopyButtons();
  })();
</script>
