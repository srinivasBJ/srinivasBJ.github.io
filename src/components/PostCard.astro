---
interface Props {
  title: string;
  description: string;
  slug: string;
  date: Date;
  readingTime: string;
  tags?: string[];
  categories?: string[];
}

const { title, description, slug, date, readingTime, categories } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="py-8 first:pt-0 last:pb-0 border-b border-[var(--color-border)] last:border-none group">
  <div class="flex flex-wrap items-center gap-3 text-xs font-mono text-[var(--color-text-tertiary)] mb-2">
    <time datetime={date.toISOString()}>{formattedDate}</time>
    <span>•</span>
    <span>{readingTime}</span>
    {categories && categories.length > 0 && (
      <>
        <span>•</span>
        <div class="flex gap-1.5">
          {categories.map((cat) => (
            <span class="uppercase tracking-wider text-[var(--color-text-secondary)]">{cat}</span>
          ))}
        </div>
      </>
    )}
  </div>

  <h3 class="font-serif text-xl font-bold tracking-tight text-[var(--color-text)] group-hover:text-[var(--color-accent-primary)] transition-colors mb-2 leading-snug">
    <a href={`/blog/${slug}`}>
      {title}
    </a>
  </h3>
  
  <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed max-w-2xl">
    {description}
  </p>
</article>
