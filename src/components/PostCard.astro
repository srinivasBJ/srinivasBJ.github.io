---
interface Props {
  title: string;
  description: string;
  slug: string;
  date: Date;
  readingTime: string;
  tags?: string[];
  categories?: string[];
}

const { title, description, slug, date, readingTime, categories } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="block group no-underline">
  <article class="surface-card overflow-hidden p-6 md:p-7">
    <!-- accent rail that lights up on hover -->
    <span class="absolute left-0 top-5 bottom-5 w-[2px] rounded-full bg-[var(--color-accent-primary)] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>

    <div class="flex flex-wrap items-center gap-2.5 text-[11px] font-mono text-[var(--color-text-tertiary)] mb-3">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      <span class="text-[var(--color-border-hover)]">/</span>
      <span>{readingTime}</span>
      {categories && categories.length > 0 && categories.map((cat) => (
        <span class="uppercase tracking-wider px-1.5 py-0.5 rounded bg-[var(--color-bg-secondary)] border border-[var(--color-border)] text-[var(--color-text-secondary)]">{cat}</span>
      ))}
    </div>

    <h3 class="font-display text-lg md:text-xl font-semibold tracking-tight text-[var(--color-text)] group-hover:text-[var(--color-accent-primary)] transition-colors mb-2 leading-snug">
      {title}
    </h3>

    <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed line-clamp-2 max-w-2xl">
      {description}
    </p>

    <span class="mt-4 inline-flex items-center gap-1.5 text-xs font-medium text-[var(--color-text-tertiary)] group-hover:text-[var(--color-accent-primary)] transition-colors">
      Read article
      <svg class="w-3.5 h-3.5 transform group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </span>
  </article>
</a>
