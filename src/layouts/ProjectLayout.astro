---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    tags: string[];
    github?: string;
    demo?: string;
    timeline?: string;
    featured?: boolean;
    accent?: string;
    logo?: string;
  };
}

const { frontmatter } = Astro.props;
const accent = frontmatter.accent ?? '#5844ea';
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <div class="max-w-4xl mx-auto px-6 py-12 md:py-20 animate-fade-in">
    <!-- Back Link -->
    <div class="mb-8">
      <a
        href="/projects"
        class="text-xs font-mono text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors inline-flex items-center gap-1.5"
      >
        ← BACK TO PROJECTS
      </a>
    </div>

    <!-- Project Banner Header — accent gradient with animated aurora -->
    <header
      class="relative mb-12 rounded-2xl overflow-hidden border border-white/15 p-8 md:p-12"
      style={`background: linear-gradient(140deg, ${accent}, color-mix(in srgb, ${accent} 60%, #000)); box-shadow: 0 24px 60px -24px ${accent}70;`}
    >
      <span class="banner-aurora"></span>
      <span class="banner-sheen"></span>
      <div class="absolute inset-0 bg-gradient-to-br from-white/10 via-transparent to-black/30 pointer-events-none"></div>

      <div class="relative z-10">
        <div class="flex items-start justify-between gap-6 mb-4">
          <div class="flex flex-wrap gap-2">
            {frontmatter.tags.map((tag) => (
              <span class="text-[11px] font-mono px-2.5 py-1 rounded-full bg-white/12 text-white/90 border border-white/10">
                {tag}
              </span>
            ))}
          </div>
          {frontmatter.logo && (
            <img src={frontmatter.logo} alt={`${frontmatter.title} logo`} class="h-12 md:h-14 w-auto object-contain drop-shadow-lg shrink-0 animate-[aurora-drift_10s_ease-in-out_infinite]" />
          )}
        </div>

        <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-white leading-tight">
          {frontmatter.title}
        </h1>
        <p class="mt-4 text-base md:text-lg text-white/80 font-normal leading-relaxed max-w-[65ch]">
          {frontmatter.description}
        </p>

        <!-- Action Links & Metadata -->
        <div class="mt-7 flex flex-wrap items-center gap-6 text-sm text-white">
        {frontmatter.timeline && (
          <div class="flex items-center gap-2 text-white/80">
            <span class="text-xs font-mono text-white/60 uppercase tracking-wider">Timeline:</span>
            <span class="font-medium">{frontmatter.timeline}</span>
          </div>
        )}

        {frontmatter.github && (
          <a
            href={frontmatter.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 font-medium text-white/90 hover:text-white transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z" clip-rule="evenodd" />
            </svg>
            GitHub Repository
          </a>
        )}

        {frontmatter.demo && (
          <a
            href={frontmatter.demo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 font-medium text-white/80 hover:text-white transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            Live Demo
          </a>
        )}
        </div>
      </div>
    </header>

    <!-- Main Project Content -->
    <article class="prose">
      <slot />
    </article>
  </div>
</BaseLayout>
