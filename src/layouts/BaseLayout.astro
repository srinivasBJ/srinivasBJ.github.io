---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import BackToTop from '../components/BackToTop.astro';
import CommandPalette from '../components/CommandPalette.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: boolean;
  publishDate?: Date;
}

const {
  title,
  description = 'Personal publishing platform and digital garden of srinivasBJ.',
  image,
  article = false,
  publishDate,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = 'srinivasBJ';
const fullTitle = title === siteName ? siteName : `${title} — ${siteName}`;
---

<!DOCTYPE html>
<html lang="en" class="">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Sitemap & RSS -->
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteName}
      href="/rss.xml"
    />

    <!-- Open Graph -->
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteName} />
    {image && <meta property="og:image" content={new URL(image, Astro.site)} />}
    {publishDate && (
      <meta
        property="article:published_time"
        content={publishDate.toISOString()}
      />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={new URL(image, Astro.site)} />}

    <!-- Theme Color -->
    <meta name="theme-color" content="#0b0a09" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fcfbf9" media="(prefers-color-scheme: light)" />

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      function applyTheme() {
        const theme = (() => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          return 'dark';
        })();
        if (theme === 'light') {
          document.documentElement.classList.add('light');
        } else {
          document.documentElement.classList.remove('light');
        }
      }
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>

    <!-- KaTeX CSS for LaTeX math rendering (formulas rendered at build time by rehype-katex) -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
      crossorigin="anonymous"
    />

    <!-- Dynamic Mermaid.js loader for rendering diagrams -->
    <script is:inline>
      function initMermaid() {
        // Shiki wraps mermaid code as: <pre data-language="mermaid"><code>...</code></pre>
        const pres = document.querySelectorAll(
          'pre[data-language="mermaid"], .language-mermaid, pre.mermaid, code.language-mermaid'
        );
        if (pres.length === 0) return;

        // Detect current theme
        const isLight = document.documentElement.classList.contains('light');

        pres.forEach((el) => {
          // Extract raw text — Shiki wraps each line in spans
          const codeEl = el.querySelector('code') || el;
          let code = codeEl.textContent || codeEl.innerText;
          code = code.trim();
          if (!code) return;

          const parent = el.closest('pre') || el;
          const container = document.createElement('div');
          container.className = 'mermaid';
          container.style.cssText = 'margin:1.5rem 0;padding:1.25rem;border-radius:8px;display:flex;justify-content:center;overflow-x:auto;border:1px solid var(--color-border);background:var(--color-bg-secondary)';
          container.textContent = code;

          parent.parentNode.replaceChild(container, parent);
        });

        // Use colors matching the original light/dark variables
        var themeVars = isLight
          ? { background: '#FDF8EE', primaryColor: '#F5EDD9', primaryTextColor: '#0f172a', lineColor: '#cbd5e1', secondaryColor: '#FFFFFF' }
          : { background: '#121212', primaryColor: '#1a1a1a', primaryTextColor: '#f4f4f5', lineColor: '#2e2e33', secondaryColor: '#161616' };

        var themeCSS = isLight
          ? `
            .node rect, .node circle, .node polygon, .node path {
              stroke: #d97706 !important;
              stroke-width: 1.5px !important;
              fill: #FDF8EE !important;
              rx: 8px !important;
              ry: 8px !important;
            }
            .node.highlight rect {
              fill: #d97706 !important;
              stroke: #b45309 !important;
            }
            .node.highlight .label {
              color: #ffffff !important;
            }
            .node .label {
              font-family: 'Inter', sans-serif !important;
              color: #3e2723 !important;
              font-weight: 500 !important;
              font-size: 13px !important;
            }
            .edgePath .path {
              stroke: #b45309 !important;
              stroke-width: 1.5px !important;
            }
            .edgePath .arrowheadPath {
              fill: #b45309 !important;
            }
            .cluster rect {
              fill: #F5EDD9 !important;
              stroke: #cbd5e1 !important;
              stroke-width: 1px !important;
              rx: 12px !important;
              ry: 12px !important;
            }
            .cluster .label {
              font-family: 'Inter', sans-serif !important;
              fill: #475569 !important;
              font-size: 11px !important;
              font-weight: 600 !important;
            }
          `
          : `
            /* Obsidian Purple Graph styling for dark mode */
            .node rect, .node circle, .node polygon, .node path {
              stroke: #8b5cf6 !important; /* Obsidian purple stroke */
              stroke-width: 1.5px !important;
              fill: #14121a !important; /* Deep dark purple-tinted background */
              rx: 8px !important; /* Clean rounded edges */
              ry: 8px !important;
            }
            /* Highlight class defined in markdown */
            .node.highlight rect {
              fill: #10b981 !important; /* Keep green highlight but styled cleanly */
              stroke: #34d399 !important;
              stroke-width: 2px !important;
            }
            .node.highlight .label {
              color: #ffffff !important;
              font-weight: 600 !important;
            }
            .node .label {
              font-family: 'Inter', sans-serif !important;
              color: #c084fc !important; /* Glowing lavender text */
              font-weight: 500 !important;
              font-size: 13px !important;
            }
            .edgePath .path {
              stroke: #6d28d9 !important; /* Smooth purple connection lines */
              stroke-width: 1.5px !important;
            }
            .edgePath .arrowheadPath {
              fill: #6d28d9 !important;
            }
            .cluster rect {
              fill: #0d0b11 !important; /* Slightly darker purple container */
              stroke: #4c1d95 !important; /* Purple border for container */
              stroke-width: 1px !important;
              rx: 12px !important;
              ry: 12px !important;
            }
            .cluster .label {
              font-family: 'Inter', sans-serif !important;
              fill: #a78bfa !important;
              font-size: 11px !important;
              font-weight: 600 !important;
            }
          `;

        const config = {
          startOnLoad: false,
          theme: isLight ? 'base' : 'dark',
          themeVariables: themeVars,
          themeCSS: themeCSS,
          flowchart: {
            htmlLabels: true,
            curve: 'basis' /* Smooth organic curves like Obsidian graph */
          }
        };

        if (window.mermaid) {
          window.mermaid.initialize(config);
          window.mermaid.init(undefined, document.querySelectorAll('.mermaid'));
        } else {
          var script = document.createElement('script');
          script.src = 'https://cdn.jsdelivr.net/npm/mermaid@10.9.1/dist/mermaid.min.js';
          script.onload = function() {
            window.mermaid.initialize(config);
            window.mermaid.init(undefined, document.querySelectorAll('.mermaid'));
          };
          document.body.appendChild(script);
        }
      }
      document.addEventListener('DOMContentLoaded', initMermaid);
      document.addEventListener('astro:page-load', initMermaid);
    </script>

    <ClientRouter />
  </head>
  <body
    class="bg-[var(--color-bg)] text-[var(--color-text)] font-sans min-h-screen flex flex-col antialiased transition-colors duration-200"
  >
    <!-- Skip to content -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:rounded-lg focus:bg-[var(--color-text)] focus:text-[var(--color-bg)] focus:outline-none"
    >
      Skip to content
    </a>

    <ScrollProgress />

    <!-- Permanent Sidebar (Desktop) -->
    <aside class="fixed top-0 left-0 bottom-0 w-56 border-r border-[var(--color-border)] bg-[var(--color-bg-secondary)] p-8 z-40 hidden md:block">
      <Sidebar />
    </aside>

    <!-- Mobile Top Header -->
    <header class="sticky top-0 w-full z-30 bg-[var(--color-bg)]/90 backdrop-blur-md border-b border-[var(--color-border)] px-6 h-14 flex items-center justify-between md:hidden">
      <a href="/" class="font-serif font-bold text-lg text-[var(--color-text)]">
        srinivasBJ
      </a>
      <button
        id="mobile-menu-toggle"
        type="button"
        class="p-2 rounded-lg hover:bg-[var(--color-bg-secondary)] transition-colors cursor-pointer"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu-drawer"
      >
        <svg class="w-5 h-5 text-[var(--color-text)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </header>

    <!-- Mobile Navigation Drawer -->
    <div
      id="mobile-drawer-overlay"
      class="fixed inset-0 z-50 bg-black/40 backdrop-blur-xs transition-opacity duration-200 hidden md:hidden"
      role="presentation"
    >
      <aside
        id="mobile-menu-drawer"
        class="w-64 h-full bg-[var(--color-bg)] border-r border-[var(--color-border)] p-8 flex flex-col justify-between transform -translate-x-full transition-transform duration-200"
      >
        <!-- Mobile Sidebar Close Header -->
        <div class="flex items-center justify-between mb-8 md:hidden">
          <span class="font-serif font-bold text-lg">Menu</span>
          <button
            id="mobile-menu-close"
            type="button"
            class="p-2 rounded-lg hover:bg-[var(--color-bg-secondary)] transition-colors cursor-pointer"
            aria-label="Close menu"
          >
            <svg class="w-5 h-5 text-[var(--color-text)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <div class="flex-1 overflow-y-auto">
          <Sidebar />
        </div>
      </aside>
    </div>

    <!-- Main Content Area -->
    <div class="md:pl-56 flex-1 min-h-screen flex flex-col">
      <main id="main-content" class="flex-1">
        <slot />
      </main>
    </div>

    <BackToTop />
    <CommandPalette />

    <!-- Mobile Drawer Handling script -->
    <script is:inline>
      (function() {
        function initDrawer() {
          const toggleBtn = document.getElementById('mobile-menu-toggle');
          const closeBtn = document.getElementById('mobile-menu-close');
          const overlay = document.getElementById('mobile-drawer-overlay');
          const drawer = document.getElementById('mobile-menu-drawer');

          if (!toggleBtn || !overlay || !drawer) return;

          function openDrawer() {
            overlay.classList.remove('hidden');
            // Force redraw before sliding in
            setTimeout(() => {
              drawer.classList.remove('-translate-x-full');
            }, 10);
            toggleBtn.setAttribute('aria-expanded', 'true');
          }

          function closeDrawer() {
            drawer.classList.add('-translate-x-full');
            setTimeout(() => {
              overlay.classList.add('hidden');
            }, 200);
            toggleBtn.setAttribute('aria-expanded', 'false');
          }

          toggleBtn.addEventListener('click', openDrawer);
          if (closeBtn) {
            closeBtn.addEventListener('click', closeDrawer);
          }
          overlay.addEventListener('click', (e) => {
            if (e.target === overlay) closeDrawer();
          });

          // Close on navigating away (view transitions page-load)
          document.addEventListener('astro:after-swap', closeDrawer);
        }

        document.addEventListener('astro:page-load', initDrawer);
        initDrawer();
      })();
    </script>
  </body>
</html>
